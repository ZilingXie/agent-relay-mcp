{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "processorStatus",
    "summary",
    "suggestedReply",
    "needsHumanReason",
    "requiresHumanConfirmation"
  ],
  "properties": {
    "processorStatus": {
      "type": "string",
      "enum": ["waiting", "needs_human", "ready_to_reply", "failed"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "suggestedReply": {
      "type": "string"
    },
    "needsHumanReason": {
      "type": "string"
    },
    "requiresHumanConfirmation": {
      "type": "boolean"
    },
    "actionIntent": {
      "type": "string",
      "enum": ["none", "submit_artifact", "close_task", "request_revision", "amend_task"],
      "default": "none"
    },
    "actionReason": {
      "type": "string",
      "default": ""
    },
    "artifactKind": {
      "type": "string",
      "default": ""
    },
    "artifactText": {
      "type": "string",
      "default": ""
    },
    "terminalReason": {
      "type": "string",
      "default": ""
    },
    "amendedDoneCriteria": {
      "type": "string",
      "default": ""
    },
    "previousGoalDisposition": {
      "type": "string",
      "enum": ["", "accepted_and_extended", "clarified", "superseded_by_human", "rejected_by_human", "cancelled_by_human"],
      "default": ""
    },
    "amendmentReason": {
      "type": "string",
      "default": ""
    },
    "newMaxTurns": {
      "type": ["integer", "null"],
      "minimum": 1,
      "default": null
    },
    "fileAccessRequests": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "reason", "access"],
        "properties": {
          "path": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "access": {
            "type": "string",
            "enum": ["read", "write", "read_write"]
          }
        }
      }
    }
  }
}

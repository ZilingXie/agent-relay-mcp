{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "subject",
    "requestText",
    "doneCriteria",
    "humanBoundaryReason",
    "to",
    "from",
    "completionOwnerAgentId"
  ],
  "properties": {
    "subject": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32
    },
    "requestText": {
      "type": "string",
      "minLength": 1
    },
    "doneCriteria": {
      "type": "string",
      "minLength": 1
    },
    "humanBoundaryReason": {
      "type": "string",
      "minLength": 1
    },
    "to": {
      "type": "string",
      "minLength": 1
    },
    "from": {
      "type": "string",
      "minLength": 1
    },
    "completionOwnerAgentId": {
      "type": "string",
      "minLength": 1
    }
  }
}

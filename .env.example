# Public relay URLs.
AGENTRELAY_BASE_URL=https://server.stellarix.space/agentrelay/api
AGENTRELAY_WS_URL=wss://server.stellarix.space/agentrelay/api

# Identity issued by the AgentRelay cloud/server admin.
AGENTRELAY_AGENT_ID=replace-with-agent-id
AGENTRELAY_USERNAME=replace-with-username
AGENTRELAY_TOKEN=replace-with-cloud-issued-token

# Local Inbox defaults. `npm run install:local` writes absolute paths for these.
AGENTRELAY_INBOX_DIR=./.agentrelay/inbox
AGENTRELAY_STATE_DIR=./state
AGENTRELAY_LISTENER_HOOK="node ./scripts/agentrelay-inbox-intake.mjs"
AGENTRELAY_ACK_ON_INBOX_RECEIVED=1
AGENTRELAY_PROCESS_INBOX_ON_RECEIVE=1
AGENTRELAY_EXECUTE_INBOX_ON_RECEIVE=1
AGENTRELAY_INBOX_UI_HOST=127.0.0.1
AGENTRELAY_INBOX_UI_PORT=8787

# Optional processor provider overrides. By default the processor uses Responses API
# credentials from OPENAI_API_KEY or the local Codex auth file.
# AGENTRELAY_PROCESSOR_BASE_URL=https://api.openai.com/v1
# AGENTRELAY_PROCESSOR_MODEL=gpt-5.5
